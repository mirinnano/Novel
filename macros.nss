;============================================================
; 追加マクロ定義ファイル - NScripter
;============================================================
; 0.txtの*defineセクションにinclude "macros.nss"を追加して使用

;============================================================
; 選択肢機能マクロ
;============================================================

; 基本的な選択肢表示マクロ
; selectopt "選択肢1",*label1,"選択肢2",*label2,"選択肢3",*label3
*selectopt
skipoff
getparam $0,%1,$2,%2,$4,%3
select $0,$1,$2,$3,$4
return

;------------------------------------------------------------
; 画面遷移マクロ
;------------------------------------------------------------

; クロスフェードで背景変更
; crossfade "ファイル名",時間
*crossfade
getparam $0,%1
if %1=0 mov %1,1000
bg $0,%1
return

; 白フェードアウト
; fadeout 時間
*fadeout
getparam %0
if %0=0 mov %0,1000
bg #FFFFFF,%0
return

; 黒フェードアウト
; fadeoutblack 時間
*fadeoutblack
getparam %0
if %0=0 mov %0,1000
bg #000000,%0
return

;------------------------------------------------------------
; 立ち絵制御マクロ
;------------------------------------------------------------

; 立ち絵を中心に表示
; chrcenter スプライト番号,"ファイル名"
*chrcenter
getparam %0,$1
lsp %0,$1,200,0
return

; 立ち絵を左側に表示
; chrleft スプライト番号,"ファイル名"
*chrleft
getparam %0,$1
lsp %0,$1,100,0
return

; 立ち絵を右側に表示
*chrright
getparam %0,$1
lsp %0,$1,300,0
return

; 全ての立ち絵を消去
*clearallchr
csp 0
csp 1
csp 2
csp 3
csp 4
csp 5
return

;------------------------------------------------------------
; テキスト効果マクロ
;------------------------------------------------------------

; テキストの色変更
; textcolor #RRGGBB
*textcolor
getparam $0
deftextstyle $0,0,0,0,0
return

; テキストを太字にする
*textbold
deftextstyle #000000,1,0,0,0
return

; テキストを標準に戻す
*textnormal
deftextstyle #000000,0,0,0,0
return

;------------------------------------------------------------
; システムコマンドマクロ
;------------------------------------------------------------

; タイトル画面へ戻る
*gototitle
reset
return

; ゲーム終了
*exitgame
end
return

; 画面をクリア
*clearscreen
csp all
erasetextwindow 1
return

;------------------------------------------------------------
; 保存・ロード関連マクロ
;------------------------------------------------------------

; セーブ画面を表示
*showsave
systemcall savegame
return

; ロード画面を表示
*showload
systemcall loadgame
return

;------------------------------------------------------------
; 特殊効果マクロ
;------------------------------------------------------------

; 画面を振るわせる
; shake 回数,強さ
*shake
getparam %0,%1
if %0=0 mov %0,5
if %1=0 mov %1,5
quake %0,%1
return

; 画面を明るくする
*flash
getparam %0
if %0=0 mov %0,500
bg #FFFFFF,%0
bg "bg_current.png",%0
return

;------------------------------------------------------------
; BGM・SEマクロの拡張
;------------------------------------------------------------

; BGMをフェードアウト
*bgmfadeout
bgmstop
return

; 特定のBGMを再生
*playbgm
getparam $0
bgm $0,0
return

;------------------------------------------------------------
; 待機マクロ
;------------------------------------------------============

; 指定時間待機（ミリ秒）
*wait
getparam %0
if %0=0 mov %0,1000
wait %0
return

; クリック待機
*clickwait
click
return

;------------------------------------------------------------
; デバッグ用マクロ
;------------------------------------------------------------

; 変数の値を表示（デバッグ用）
*debugvar
getparam %0
mov $0,"変数"
add $0,%0
$0\
return

;------------------------------------------------------------
; シーン切り替え用マクロ
;------------------------------------------------------------

; シーンの開始（黒フェード→背景表示）
*scenestart
bg #000000,500
getparam $0,%1
if %1=0 mov %1,1000
bg $0,%1
return

; シーンの終了（背景→黒フェード）
*sceneend
getparam %0
if %0=0 mov %0,1000
bg #000000,%0
return

;============================================================
; 使用例
;============================================================
;
; 0.txtの*defineセクションに以下を追加：
; include "macros.nss"
;
; 使用例：
; scstart "bg_rooftop.png",1000
; talk "ミオ","「こんにちは」"
; selectopt "選択肢1",*label1,"選択肢2",*label2
;
; *label1
; scend 500
; reset
;
;============================================================
